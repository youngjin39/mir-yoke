    "repository_overlay": {
      "description": "Remember the repository-local overlay contract that narrows how the harness may manage this repository.",
      "memory_focus": [
        "repo-profile",
        "preserve boundaries",
        "overlay archetype"
      ]
    },
    "generation_verification_pipeline": {
      "description": "Remember the scripts, compilers, and verifiers that regenerate or prove the repository's agent surfaces.",
