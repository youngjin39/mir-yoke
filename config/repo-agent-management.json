        "profile compiler",
        "Codex derivation",
        "verifier sequence"
      ]
    },
    "operating_contract": {
      "description": "Remember the durable ledgers and rules that agents must maintain during day-to-day work.",
      "memory_focus": [
        "tasks/plan.md",
        "tasks/tdd.json",
        "change log and decision trail"
      ]
    },
    "harness_structure": {
      "description": "Remember the main structural surfaces that make the harness present in the repository.",
