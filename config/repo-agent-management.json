        "agents",
        "hooks",
        "skills",
        "runtime policy split"
      ]
    },
    "harness_format": {
      "description": "Remember the generated format and packaging surfaces that must stay mechanically consistent.",
      "memory_focus": [
        "codex mirrors",
        "hook settings",
        "plugin/commands packaging"
      ]
