{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mir/config/parity-manifest",
  "$comment": "ADR-54 D1 — schema for the generated config/parity-manifest.json artifact. This mir-self copy is canonical; copying it into the public template is a separate orchestrated template release step.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_version",
    "template_commit",
    "generated_at",
    "normalization",
    "files"
  ],
  "properties": {
    "template_version": {
      "type": "string"
    },
    "template_commit": {
      "type": "string",
      "pattern": "^(unknown|[0-9a-f]{40})$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verbatim",
        "parameterized",
        "marker-block",
        "family-owned",
        "slug_placeholder",
        "template_slug"
      ],
      "properties": {
        "verbatim": {
          "type": "string"
        },
        "parameterized": {
          "type": "string"
        },
        "marker-block": {
          "type": "string"
        },
        "managed-keys": {
          "type": "string"
        },
        "family-owned": {
          "type": "string"
        },
        "slug_placeholder": {
          "const": "{{SLUG}}"
        },
        "template_slug": {
          "type": "string"
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/file"
      }
    }
  },
  "definitions": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "params": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "slug_site_count": {
          "type": "integer",
          "minimum": 0
        },
        "marker_name": {
          "type": "string"
        },
        "marker_begin": {
          "type": "string"
        },
        "marker_end": {
          "type": "string"
        },
        "projection": {
          "type": "string"
        },
        "history_depth": {
          "type": "integer",
          "minimum": 1
        },
        "note": {
          "type": "string"
        }
      }
    },
    "parameterized_params": {
      "allOf": [
        {
          "$ref": "#/definitions/params"
        },
        {
          "required": [
            "slug_site_count"
          ]
        }
      ]
    },
    "marker_block_params": {
      "allOf": [
        {
          "$ref": "#/definitions/params"
        },
        {
          "required": [
            "marker_name",
            "marker_begin",
            "marker_end"
          ]
        }
      ]
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "ownership_class",
        "hash",
        "previous_hashes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "ownership_class": {
          "enum": [
            "verbatim",
            "parameterized",
            "marker-block",
            "managed-keys",
            "family-owned"
          ]
        },
        "hash": {
          "anyOf": [
            {
              "$ref": "#/definitions/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "previous_hashes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/sha256"
          }
        },
        "params": {
          "$ref": "#/definitions/params"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "ownership_class": {
                "const": "family-owned"
              }
            },
            "required": [
              "ownership_class"
            ]
          },
          "then": {
            "properties": {
              "hash": {
                "type": "null"
              },
              "previous_hashes": {
                "type": "array",
                "maxItems": 0
              }
            }
          },
          "else": {
            "properties": {
              "hash": {
                "$ref": "#/definitions/sha256"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ownership_class": {
                "const": "parameterized"
              }
            },
            "required": [
              "ownership_class"
            ]
          },
          "then": {
            "required": [
              "params"
            ],
            "properties": {
              "params": {
                "$ref": "#/definitions/parameterized_params"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ownership_class": {
                "const": "marker-block"
              }
            },
            "required": [
              "ownership_class"
            ]
          },
          "then": {
            "required": [
              "params"
            ],
            "properties": {
              "params": {
                "$ref": "#/definitions/marker_block_params"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ownership_class": {
                "const": "managed-keys"
              }
            },
            "required": [
              "ownership_class"
            ]
          },
          "then": {
            "required": [
              "params"
            ],
            "properties": {
              "params": {
                "allOf": [
                  {
                    "$ref": "#/definitions/params"
                  },
                  {
                    "required": [
                      "projection"
                    ]
                  }
                ]
              }
            }
          }
        }
      ]
    }
  }
}
