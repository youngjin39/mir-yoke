{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mir-harness.local/schemas/design_doc.schema.json",
  "title": "Design Document",
  "description": "Design document — a design phase, ADR, or schema artifact. Captures user_intent and the 5 design_goals axes.",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "status",
    "created",
    "design_goals",
    "problem",
    "grep_evidence",
    "alternatives",
    "decision",
    "acceptance_criteria"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "kebab-case slug. e.g. fleet-catalog-2026-05-23"
    },
    "title": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["phase", "adr", "schema", "skill", "agent", "hook", "config"],
      "description": "The kind of design artifact."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved", "superseded", "rejected"]
    },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "owner": { "type": "string", "description": "agent or user identifier" },

    "materials": {
      "type": "array",
      "description": "Inputs treated as material, not ground truth; each classified before it informs the design.",
      "items": {
        "type": "object",
        "required": ["source", "state"],
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string" },
          "state": {
            "type": "string",
            "enum": ["confirmed", "derived", "observed", "assumed", "conflict", "open", "tunable"]
          },
          "note": { "type": "string" }
        }
      }
    },

    "decision_surface": {
      "type": "array",
      "description": "Load-bearing decisions enumerated across axes; only genuinely-open, high-cost ones are surfaced.",
      "items": {
        "type": "object",
        "required": ["axis", "decision", "state"],
        "additionalProperties": false,
        "properties": {
          "axis": {
            "type": "string",
            "enum": ["goal_boundary", "actors", "data_state", "behavior", "safety_policy", "compatibility_ops", "verification"]
          },
          "decision": { "type": "string" },
          "state": {
            "type": "string",
            "enum": ["confirmed", "derived", "assumed", "open", "conflict", "tunable"]
          },
          "surfaced": { "type": "boolean" }
        }
      }
    },

    "open_decisions": {
      "type": "array",
      "description": "The subset of decision-surface entries surfaced to the user.",
      "items": {
        "type": "object",
        "required": ["question", "recommendation"],
        "additionalProperties": false,
        "properties": {
          "question": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" } },
          "recommendation": { "type": "string" },
          "rationale": { "type": "string" },
          "resolution": { "type": "string" }
        }
      }
    },

    "authority_notes": {
      "type": "string",
      "description": "Where code/memory/prior decisions were treated as material vs. authority, and how any spec-vs-code conflict was resolved."
    },

    "migration_closure": {
      "type": "array",
      "description": "For existing-code onboarding, each item and how it was closed; not_applicable requires a reason.",
      "items": {
        "type": "object",
        "required": ["item", "closure"],
        "additionalProperties": false,
        "properties": {
          "item": { "type": "string" },
          "closure": {
            "type": "string",
            "enum": ["code_confirmed", "user_confirmed", "derived", "not_applicable", "unresolved", "conflict"]
          },
          "reason": { "type": "string" }
        },
        "allOf": [
          {
            "if": {
              "properties": { "closure": { "const": "not_applicable" } },
              "required": ["closure"]
            },
            "then": { "required": ["reason"] }
          }
        ]
      }
    },

    "design_goals": {
      "type": "object",
      "description": "The 5 required design-goals axes — all must be present and non-vacuous.",
      "required": [
        "axis_i_mir_self",
        "axis_ii_template_sync",
        "axis_iii_fleet_share",
        "inter_phase_input",
        "inter_phase_output"
      ],
      "additionalProperties": false,
      "properties": {
        "axis_i_mir_self": {
          "type": "string",
          "minLength": 20,
          "description": "How this contributes to the source harness engineering."
        },
        "axis_ii_template_sync": {
          "type": "string",
          "minLength": 20,
          "description": "How this is reflected in the public template baseline."
        },
        "axis_iii_fleet_share": {
          "type": "string",
          "minLength": 20,
          "description": "How this flows to/from fleet families (opt-in)."
        },
        "inter_phase_input": {
          "type": "string",
          "minLength": 10,
          "description": " prior phase / artifact  "
        },
        "inter_phase_output": {
          "type": "string",
          "minLength": 10,
          "description": " next phase / artifact  "
        }
      }
    },

    "problem": {
      "type": "string",
      "minLength": 30,
      "description": " . 1 paragraph."
    },

    "grep_evidence": {
      "type": "array",
      "minItems": 1,
      "description": "Evidence that existing code was grep-searched before proposing new modules/CLI/hooks.",
      "items": {
        "type": "object",
        "required": ["location", "query", "hit_count", "reviewed_at"],
        "additionalProperties": false,
        "properties": {
          "location": {
            "type": "string",
            "enum": [
              "docs/decisions",
              "memory/MEMORY.md",
              " ",
              "tasks/lessons.md",
              "docs/architecture",
              "docs/harness-engineering",
              "config/repos",
              "other"
            ]
          },
          "query": { "type": "string", "minLength": 1 },
          "hit_count": { "type": "integer", "minimum": 0 },
          "reviewed_at": { "type": "string", "format": "date-time" },
          "summary": { "type": "string" }
        }
      }
    },

    "alternatives": {
      "type": "array",
      "minItems": 2,
      "description": "At least 2 alternatives considered, with 1+ rejected and the reason.",
      "items": {
        "type": "object",
        "required": ["name", "summary", "decision"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "summary": { "type": "string", "minLength": 20 },
          "decision": {
            "type": "string",
            "enum": ["adopted", "rejected", "deferred"]
          },
          "rejection_reason": { "type": "string" }
        }
      }
    },

    "decision": {
      "type": "string",
      "minLength": 30,
      "description": "  . 1 paragraph."
    },

    "interfaces": {
      "type": "object",
      "description": "The interface (schema / API / contract).",
      "properties": {
        "input_schema": { "type": "string", "description": "schema  path  inline" },
        "output_schema": { "type": "string" },
        "side_effects": { "type": "array", "items": { "type": "string" } }
      }
    },

    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 10 },
      "description": "Verifiable acceptance criteria for the design."
    },

    "test_plan": {
      "type": "string",
      "description": "TDD plan  regression test "
    },

    "rollback": {
      "type": "string",
      "description": "Rollback plan once the change lands (e.g., git revert / config restore)."
    },

    "review_round_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Review-round identifiers for this design."
    },

    "related_adrs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^adr-[0-9]+" }
    }
  }
}
