{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh",
            "timeout": 30,
            "statusMessage": "Harness L2 PreToolUse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-check.sh",
            "timeout": 30,
            "statusMessage": "Harness post-edit check"
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-self-ingest.sh",
            "timeout": 30,
            "statusMessage": "ADR-05 self-ingest"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh",
            "timeout": 30,
            "statusMessage": "Harness L2 PermissionRequest"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 30,
            "statusMessage": "Harness session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-end.sh",
            "timeout": 60,
            "statusMessage": "Harness canonical closeout"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/user-prompt-submit.sh",
            "timeout": 30,
            "statusMessage": "Harness context-pull directive"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/mir-stop.sh",
            "timeout": 30,
            "statusMessage": "Harness Stop audit"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-failure-audit.sh",
            "timeout": 30,
            "statusMessage": "Harness StopFailure audit"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-compact.sh",
            "timeout": 60,
            "statusMessage": "Harness PreCompact checkpoint"
          }
        ]
      }
    ]
  }
}
