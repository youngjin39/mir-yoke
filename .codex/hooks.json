{
  "//": [
    "Codex hook trigger surface: 8 events (PreToolUse, PostToolUse, PreCompact, PostCompact,",
    "  SessionStart, UserPromptSubmit, Stop, PermissionRequest).",
    "Claude-only events not mirrored here: TaskCreated, TaskCompleted, StopFailure.",
    "  Those require Claude Code settings.json (project_hooks_trigger_surface memory 2026-05-09)."
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh",
            "timeout": 30,
            "statusMessage": "Harness L2 PreToolUse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-check.sh",
            "timeout": 30,
            "statusMessage": "Harness post-edit check"
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-self-ingest.sh",
            "timeout": 30,
            "statusMessage": "ADR-05 self-ingest"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh",
            "timeout": 30,
            "statusMessage": "Harness L2 PermissionRequest"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 30,
            "statusMessage": "Harness session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/mir-stop.sh",
            "timeout": 30,
            "statusMessage": "Harness Stop audit"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-compact.sh",
            "timeout": 60,
            "statusMessage": "Harness PreCompact checkpoint"
          }
        ]
      }
    ]
  }
}
