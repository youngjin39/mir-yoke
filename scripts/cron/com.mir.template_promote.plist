<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.mir.template_promote</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/python3</string>
		<string>-m</string>
		<string>tools.template_promote</string>
		<string>--format</string>
		<string>markdown</string>
	</array>
	<key>WorkingDirectory</key>
	<string><your-harness-path></string>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Weekday</key>
		<integer>6</integer>
		<key>Hour</key>
		<integer>6</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>
	<key>StandardOutPath</key>
	<string>/tmp/com.mir.template_promote.out</string>
	<key>StandardErrorPath</key>
	<string>/tmp/com.mir.template_promote.err</string>
	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
